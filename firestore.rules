rules_version = '2';

// ===========================================================================
//  BBlade — Firestore rules
//
//  Access model (current): a verified Google sign-in is required for all data.
//  The member email allowlist that decides *who* may use an account is still
//  enforced in the client (AuthContext), NOT here — so any signed-in user can
//  technically reach this account's data via the API. These rules scope access
//  to the real data shape and block everything else, but do not yet provide
//  per-tenant / per-role isolation.
//
//  NEXT (proper lockdown): stamp an `accountId` (+ `role`) custom claim on each
//  user via a Cloud Function when they're added as a member, then tighten to:
//      allow read, write: if request.auth.token.accountId == accountId;
//  with role checks (e.g. owner/manager) on member + venue writes.
// ===========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // A real, verified Google account.
    function signedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Customer account (name, entitlements) and everything beneath it.
    match /accounts/{accountId} {
      allow read, write: if signedIn();

      // Staff / members (identity, role, venue access).
      match /members/{memberId} {
        allow read, write: if signedIn();
      }

      // Venues, and the stock data within each.
      match /venues/{venueId} {
        allow read, write: if signedIn();

        match /stockItems/{itemId} {
          allow read, write: if signedIn();
        }

        match /stockSessions/{sessionId} {
          allow read, write: if signedIn();
        }

        match /wastageLog/{entryId} {
          allow read, write: if signedIn();
        }

        match /deliveryLog/{entryId} {
          allow read, write: if signedIn();
        }

        match /salesReports/{reportId} {
          allow read, write: if signedIn();
        }

        match /rotas/{rotaId} {
          allow read, write: if signedIn();
        }

        match /rotaPrefs/{docId} {
          allow read, write: if signedIn();
        }
      }
    }

    // Deny anything outside the modelled paths above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
