rules_version = '2';

// ===========================================================================
//  Bar Blade — Firestore rules
//
//  Stage: Google sign-in is required (request.auth != null). App-level
//  authorization (the member email allowlist) decides who may use a given
//  account. These rules do NOT yet enforce per-tenant isolation — any signed-in
//  user can technically read/write any account via the API.
//
//  NEXT: when accounts have an `accountId` (and role) custom claim, tighten to:
//    match /accounts/{accountId}/{document=**} {
//      allow read, write: if request.auth.token.accountId == accountId;
//    }
//  plus finer per-venue / per-role checks.
// ===========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // A customer account and everything beneath it (members, venues, stock).
    match /accounts/{accountId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
