rules_version = '2';

// ===========================================================================
//  BBlade — Firestore rules
//
//  Access model: authentication is provisioned from the members list (see
//  functions/index.js) — self sign-up is disabled and the gateUserSignIn
//  blocking function rejects non-members, stamping { accountId, role } into
//  every allowed user's token (platform staff additionally get platformAdmin).
//  These rules trust those claims:
//
//    - member(account):  any signed-in member of THIS account (tenant isolation)
//    - manager(account): the account's owners/managers
//    - platformAdmin:    BBlade staff — full access across accounts
//
//  Day-to-day venue data (stock, wastage, rota reads) is member-level; account
//  configuration and back-office data (members, venues, sales, deliveries,
//  till mappings, rota writes) is manager-level. Department / with-stock
//  scoping stays client-side for now — those flags live on member docs, not
//  in token claims.
// ===========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function platformAdmin() {
      return request.auth != null && request.auth.token.platformAdmin == true;
    }
    function member(accountId) {
      return platformAdmin()
        || (request.auth != null && request.auth.token.accountId == accountId);
    }
    function manager(accountId) {
      return platformAdmin()
        || (member(accountId) && request.auth.token.role in ['owner', 'manager']);
    }

    // Customer account (name, entitlements).
    match /accounts/{accountId} {
      allow read: if member(accountId);
      allow write: if manager(accountId);

      // Staff / members (identity, role, department, feature flags).
      // All members may read (names drive attribution and rota display);
      // only managers may change the staff list.
      match /members/{memberId} {
        allow read: if member(accountId);
        allow write: if manager(accountId);
      }

      match /venues/{venueId} {
        allow read: if member(accountId);
        allow write: if manager(accountId);

        // ---- day-to-day staff data ----
        match /stockItems/{itemId} {
          allow read, write: if member(accountId);
        }
        match /stockSessions/{sessionId} {
          allow read, write: if member(accountId);
        }
        match /wastageLog/{entryId} {
          allow read, write: if member(accountId);
        }
        // Punch clock — staff clock themselves in/out; managers edit/approve
        // in Timesheets. Backdate approval fields are manager-set but staff
        // create the pending request, so writes stay member-level.
        match /shifts/{shiftId} {
          allow read, write: if member(accountId);
        }
        // Annual-leave requests — staff create their own (pending); managers
        // approve/decline (approval writes A/L onto the rota, which is
        // manager-gated below). Member-level, same model as shifts.
        match /leaveRequests/{requestId} {
          allow read, write: if member(accountId);
        }
        // Shift give-aways & swaps — staff create/claim/accept/cancel their
        // own; managers approve/decline. Applying the result to the rota is
        // the manager-gated rotas write below, so staff can never move shifts
        // themselves. Member-level, same caveat as leaveRequests: per-field
        // guarding stays client-side for now.
        match /shiftRequests/{requestId} {
          allow read, write: if member(accountId);
        }
        match /rotas/{rotaId} {
          allow read: if member(accountId);
          allow write: if manager(accountId);
        }
        match /rotaPrefs/{docId} {
          allow read: if member(accountId);
          allow write: if manager(accountId);
        }

        // ---- owner/manager features ----
        match /deliveryLog/{entryId} {
          allow read, write: if manager(accountId);
        }
        match /salesReports/{reportId} {
          allow read, write: if manager(accountId);
        }
        match /tillProducts/{productId} {
          allow read, write: if manager(accountId);
        }
      }
    }

    // Platform config (e.g. platform/config { superAdmins: [...] }). The Cloud
    // Functions read it via the Admin SDK (bypasses rules); this scopes any
    // client access to platform super-admins only.
    match /platform/{docId} {
      allow read, write: if platformAdmin();
    }

    // Shared product catalog — cross-venue lookup that pre-fills category and
    // suggests the size when adding stock. Read-only for every signed-in
    // member; curated by platform staff (reseeded by script) so one venue's
    // typo can't feed suggestions to another.
    match /catalog/{productId} {
      allow read: if request.auth != null;
      allow write: if platformAdmin();
    }

    // Deny anything outside the modelled paths above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
